# vim: ft=gitconfig
[user]
    name = alexis-moins
    email = sinus.nacre0v@icloud.com

[init]
    defaultBranch = main

[core]
    editor = nvim
    pager = delta

[delta]
    tabs = 6
    side-by-side = true
    true-color = always

    navigate = true
    file-modified-label = "~"

    syntax-theme = Rose-Pine-Moon

    plus-style = syntax "#3b4456"
    minus-style = syntax "#4b3148"

    line-numbers-plus-style = "#9ccfd8"
    line-numbers-minus-style = "#eb6f92"

    plus-emph-style = "#9ccfd8" ul "#3b4456"
    minus-emph-style = "#eb6f92" ul "#4b3148"

[diff]
    colorMoved = default
    mnemonicPrefix = true

[interactive]
    diffFilter = delta --color-only

[color "diff"]
    meta = bold black

[difftool]
    prompt = true

[merge]
    conflictstyle = diff3

[mergetool]
    prompt = false
    keepBackup = false

[rerere]
    enabled = true

[branch]
    sort = -committerdate

[alias]
    ci = commit
    amend = commit --amend --no-edit

    tags = tag
    stashes = stash list
    branches = branch --format '%(color:yellow)%(HEAD) %(color:reset)%(refname:short) %(color:red)%(upstream:short) %(color:reset)[%(color:bold black)%(authorname) %(color:reset), %(color:bold black)%(committerdate:relative)%(color:reset)] %(upstream:track)'

    unstage = restore --staged --
    discard = checkout --

    untracked = ls-files --others --exclude-standard

    fap = fetch --all --prune
    current = rev-parse --abbrev-ref HEAD

    bl = branch --format '%(color:yellow)[%(HEAD)]%(color:white) %(refname:short) %(color:red)%(upstream:short) %(color:cyan)%(authorname) %(color:bold black)(%(committerdate:relative)) %(color:bold green)%(upstream:track)'
    blr = branch --remote --format '%(color:red)[%(HEAD)]%(color:white) %(refname:short) %(color:blue)%(authorname) %(color:bold black)%(committerdate:relative)'

    uncommit = reset HEAD^
    remove-commit = reset --hard HEAD^

    diff-staged = diff --staged
    diff-unstaged = diff --diff-filter=M
    precommit = diff --staged --diff-algorithm=minimal --ignore-all-space

    graph = log --graph -n20 --format='format:%C(yellow)%h %C(reset)[%C(red)%an%C(reset), %C(green)%cr%C(reset)] %C(reset)%<(100,trunc)%s %C(auto)%d'

    ignore = !git rm -r --cached . && git add --all

[format]
    ; Pretty format used for the log command
    pretty = format:%C(yellow)%h %C(reset)[%C(red)%an%C(reset), %C(green)%cr%C(reset)] %C(reset)%<(100,trunc)%s

[push]
    autoSetupRemote = true
    default = "current"

[remote "origin"]
    prune = true

[pull]
    rebase = true
